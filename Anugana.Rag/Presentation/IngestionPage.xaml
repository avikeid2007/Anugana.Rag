<Page x:Class="Anugana.Rag.Presentation.IngestionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Anugana.Rag.Presentation"
      xmlns:models="using:Anugana.Rag.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <local:BoolToVisibilityConverter x:Key="BoolToVis" />
  </Page.Resources>

  <ScrollViewer IsTabStop="True">
    <Grid utu:SafeArea.Insets="VisibleBounds" RowSpacing="14" Padding="14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Header -->
      <StackPanel Grid.Row="0">
        <TextBlock Text="📄 Knowledge Base Pipeline" FontSize="20" FontWeight="Bold" />
        <TextBlock Text="Parse and index PDF, TXT, and MD documents into Qdrant" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontSize="12" />
      </StackPanel>

      <!-- Collection Stats Cards (Responsive Grid) -->
      <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Vectors Card -->
        <Border Grid.Column="0" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
          <StackPanel Spacing="4">
            <TextBlock Text="Indexed Vectors" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            <TextBlock Text="{Binding PointsCount}" FontSize="22" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
          </StackPanel>
        </Border>

        <!-- Status Card -->
        <Border Grid.Column="1" CornerRadius="10" Padding="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
          <Grid>
            <StackPanel Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="Vector DB Status" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
              <TextBlock Text="{Binding CollectionStatus}" FontSize="18" FontWeight="SemiBold" />
            </StackPanel>
            <Button Command="{Binding RefreshStatsCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Padding="4" Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="Refresh stats">
              <TextBlock Text="🔄" FontSize="12" />
            </Button>
          </Grid>
        </Border>
      </Grid>

      <!-- Multi-File Ingest Card -->
      <Border Grid.Row="2" CornerRadius="12" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="12">
          <TextBlock Text="Ingest Documents" FontWeight="SemiBold" FontSize="15" />
          <TextBlock Text="Select single or multiple PDF, TXT, or MD documents to parse, embed, and index into your vector database." Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontSize="12" TextWrapping="Wrap" />

          <!-- Primary File Picker Action -->
          <Button Click="SelectFilesButton_Click"
                  Background="{ThemeResource SystemControlHighlightAccentBrush}"
                  Foreground="White"
                  Padding="16,10"
                  CornerRadius="8"
                  HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
              <TextBlock Text="📁" FontSize="16" />
              <TextBlock Text="Browse &amp; Select Files (Multi-Select)" FontWeight="SemiBold" FontSize="14" />
            </StackPanel>
          </Button>

          <!-- Progress / Status Line -->
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
            <ProgressRing IsActive="{Binding IsProcessing}" Width="16" Height="16"
                          Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                          VerticalAlignment="Center" />
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="Medium" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <!-- Optional Manual Path Input -->
          <Expander Header="Or enter manual file path..." HorizontalAlignment="Stretch" Margin="0,2,0,0">
            <Grid ColumnSpacing="8" Margin="0,6,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBox Text="{Binding FilePathInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="Enter full file path (e.g. C:\Docs\manual.pdf)..."
                       CornerRadius="6" />

              <Button Grid.Column="1" Content="Ingest Path 📥" Command="{Binding IngestFileCommand}" CornerRadius="6" />
            </Grid>
          </Expander>
        </StackPanel>
      </Border>

      <!-- Ingested Documents List -->
      <StackPanel Grid.Row="3" Spacing="8">
        <TextBlock Text="Recent Ingested Documents" FontWeight="SemiBold" FontSize="15" />
        <ListView ItemsSource="{Binding Documents}" SelectionMode="None">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="models:IngestedDocument">
              <Border CornerRadius="8" Padding="10,8" Margin="0,3,0,3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid ColumnSpacing="10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="📄" FontSize="18" VerticalAlignment="Center" />

                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding FilePath}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextTrimming="CharacterEllipsis" />
                  </StackPanel>

                  <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Status}" FontWeight="Bold" FontSize="12" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                    <TextBlock Text="{Binding FormattedChunkCount}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </StackPanel>

    </Grid>
  </ScrollViewer>
</Page>
