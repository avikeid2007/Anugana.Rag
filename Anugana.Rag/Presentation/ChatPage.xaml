<Page x:Class="Anugana.Rag.Presentation.ChatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Anugana.Rag.Presentation"
      xmlns:models="using:Anugana.Rag.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <local:BoolToVisibilityConverter x:Key="BoolToVis" />
  </Page.Resources>

  <Grid utu:SafeArea.Insets="VisibleBounds" RowSpacing="10" Padding="12,12,12,8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header Bar -->
    <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="💬 RAG Inference Chat" FontSize="20" FontWeight="Bold" />
        <TextBlock Text="Powered by your vector knowledge base" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontSize="12" />
      </StackPanel>

      <Button Grid.Column="1"
              Content="Clear Chat"
              Command="{Binding ClearMessagesCommand}"
              VerticalAlignment="Center"
              Padding="10,6"
              CornerRadius="6"
              FontSize="12" />
    </Grid>

    <!-- Chat Messages List -->
    <ListView Grid.Row="1" ItemsSource="{Binding Messages}" SelectionMode="None">
      <ListView.ItemContainerStyle>
        <Style TargetType="ListViewItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Padding" Value="0,4" />
        </Style>
      </ListView.ItemContainerStyle>
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="models:ChatMessage">
          <Grid Margin="0,4,0,4">
            <!-- Message Card Container -->
            <Border CornerRadius="12" Padding="14"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
              <StackPanel Spacing="6">
                <!-- Message Header -->
                <Grid ColumnSpacing="8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <TextBlock Text="{Binding Sender}" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                  
                  <TextBlock Grid.Column="2" Text="{Binding FormattedTimestamp}" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />

                  <!-- Copy Button -->
                  <Button Grid.Column="3"
                          Command="{Binding CopyCommand}"
                          ToolTipService.ToolTip="Copy message text"
                          Padding="6,2"
                          CornerRadius="4"
                          Background="Transparent"
                          BorderThickness="0"
                          VerticalAlignment="Center">
                    <TextBlock Text="{Binding CopyButtonText}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                  </Button>
                </Grid>

                <!-- Thinking / Searching Indicator -->
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,4,0,4"
                            Visibility="{Binding IsThinking, Converter={StaticResource BoolToVis}}">
                  <ProgressRing IsActive="True" Width="16" Height="16" VerticalAlignment="Center" />
                  <TextBlock Text="🤔 Searching knowledge base &amp; thinking..."
                             FontStyle="Italic"
                             FontSize="13"
                             Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"
                             VerticalAlignment="Center" />
                </StackPanel>

                <!-- Markdown Formatted Message Body -->
                <RichTextBlock local:MarkdownHelper.MarkdownText="{Binding Content}"
                               TextWrapping="Wrap"
                               FontSize="14"
                               LineHeight="22"
                               IsTextSelectionEnabled="True" />

                <!-- Source Citations List -->
                <ItemsControl ItemsSource="{Binding Citations}" Margin="0,8,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:VectorSearchResult">
                      <Border Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" CornerRadius="6" Padding="8,5" Margin="0,2,0,2">
                        <Grid ColumnSpacing="6">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>

                          <TextBlock Text="📌" FontSize="11" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1" Text="{Binding FileName}" FontWeight="SemiBold" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Page" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Text="{Binding PageIndex}" FontSize="11" FontWeight="SemiBold" />
                            <TextBlock Text="|" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Text="{Binding FormattedScore}" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <!-- Bottom Mobile-Friendly Input Bar -->
    <Grid Grid.Row="2" ColumnSpacing="8" Margin="0,4,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBox x:Name="InputTextBox"
               Text="{Binding UserInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="Type query... (Enter to send, Shift+Enter for new line)"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               KeyDown="InputTextBox_KeyDown"
               MaxHeight="100"
               CornerRadius="8"
               Padding="10,8" />

      <Button Grid.Column="1"
              Content="Send 🚀"
              Command="{Binding SendMessageCommand}"
              Background="{ThemeResource SystemControlHighlightAccentBrush}"
              Foreground="White"
              FontWeight="SemiBold"
              CornerRadius="8"
              VerticalAlignment="Bottom"
              Height="38"
              Padding="14,0" />
    </Grid>
  </Grid>
</Page>
